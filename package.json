{
  "name": "tilleggsstonader-brev-sanity",
  "private": true,
  "version": "1.0.0",
  "main": "package.json",
  "license": "UNLICENSED",
  "scripts": {
    "ci": "yarn --prefer-offline --frozen-lockfile",
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "deploy-graphql": "sanity graphql deploy",
    "lint": "eslint 'src/**/*'",
    "lint:fix": "eslint 'src/**/*' --fix",
    "prettier": "prettier --write",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ]
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@portabletext/react": "^6.2.0",
    "@sanity/client": "^7.20.0",
    "@sanity/ui": "^3.2.0",
    "@sanity/vision": "^5.25.1",
    "date-fns": "^4.1.0",
    "globals": "^17.6.0",
    "groq": "^5.25.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "sanity": "^5.25.1",
    "styled-components": "^6.4.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.2.13",
    "@types/styled-components": "^5.1.36",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "prettier": {
    "semi": true,
    "printWidth": 100,
    "bracketSpacing": true,
    "singleQuote": true
  }
}
